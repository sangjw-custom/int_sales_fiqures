import win32com.client as win32
import pandas as pd
import firebase_admin
from firebase_admin import credentials, firestore
import os
import time

# --- [설정 영역] ---
# 1. Firebase 키 파일 경로
KEY_PATH = "int-sales-figures_01.json" 
# 2. 업로드할 보안 엑셀 파일의 전체 경로 (r을 붙여주세요)
EXCEL_FILE_PATH = r"C:\Users\YourName\Documents\▣ 영업본부 26년 3월 손익 DATA (260403)_상품.xlsb"
# 3. Firestore 컬렉션 이름
COLLECTION_NAME = "int-sales-figures"
# ------------------

def initialize_firebase():
    if not firebase_admin._apps:
        cred = credentials.Certificate(KEY_PATH)
        firebase_admin.initialize_app(cred)
    return firestore.client()

def read_secure_excel(file_path):
    print(f"📌 보안 문서 읽기 시작: {os.path.basename(file_path)}")
    # 실제 설치된 엑셀 앱을 구동 (DRM 통과용)
    excel = win32.gencache.EnsureDispatch('Excel.Application')
    excel.Visible = False # 엑셀 창은 숨김
    
    try:
        wb = excel.Workbooks.Open(file_path)
        ws = wb.ActiveSheet
        
        # 전체 데이터 영역 읽기
        raw_data = ws.UsedRange.Value
        
        # Pandas 데이터프레임으로 변환
        # 첫 번째 줄은 컬럼명(Header), 나머지는 데이터
        df = pd.DataFrame(raw_data[1:], columns=raw_data[0])
        
        wb.Close(False)
        print(f"✅ 데이터 로드 완료: 총 {len(df):,}행")
        return df
    except Exception as e:
        print(f"❌ 엑셀 읽기 오류: {e}")
        return None
    finally:
        excel.Quit()

def upload_to_firestore(df, collection_name):
    db = initialize_firebase()
    collection_ref = db.collection(collection_name)
    
    # NaN(빈값) 처리: Firestore는 NaN을 인식 못하므로 None으로 변경
    df = df.where(pd.notnull(df), None)
    
    batch = db.batch()
    total_rows = len(df)
    start_time = time.time()

    print(f"🚀 {total_rows:,}건의 데이터 업로드를 시작합니다...")

    for index, row in df.iterrows():
        # 각 행을 딕셔너리로 변환하여 문서 생성
        doc_ref = collection_ref.document()
        batch.set(doc_ref, row.to_dict())
        
        # 500개마다 커밋 (Firestore 제한사항)
        if (index + 1) % 500 == 0:
            batch.commit()
            batch = db.batch()
            elapsed = time.time() - start_time
            print(f"📦 {index + 1:,} / {total_rows:,} 완료 (소요시간: {elapsed:.1f}초)")

    # 남은 데이터 최종 커밋
    batch.commit()
    print(f"\n✨ 업로드 완료! 총 {total_rows:,}건이 저장되었습니다.")

if __name__ == "__main__":
    # 1. 엑셀 데이터 가져오기
    sales_df = read_secure_excel(EXCEL_FILE_PATH)
    
    # 2. 데이터가 정상적으로 로드되었다면 업로드 진행
    if sales_df is not None:
        upload_to_firestore(sales_df, COLLECTION_NAME)
